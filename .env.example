# Backend
BACKEND_PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/rmp
AI_SERVER_URL=http://localhost:8000
AI_REQUEST_TIMEOUT_MS=900000
AI_HEALTH_TIMEOUT_MS=5000
JWT_SECRET=change_me

# AI Service
AI_HOST=0.0.0.0
AI_PORT=8000
AI_PIPELINE_MODE=demo
AI_TEMP_DIR=

# STT
STT_PROVIDER=whisper
WHISPER_MODEL=tiny
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
WHISPER_CPU_THREADS=2
AI_MAX_AUDIO_UPLOAD_BYTES=26214400

# STT chunking for long recordings
STT_CHUNKING_ENABLED=true
STT_CHUNK_SECONDS=600
STT_CHUNK_OVERLAP_SECONDS=8
STT_CHUNK_MIN_DURATION_SECONDS=660
STT_CHUNK_COMMAND_TIMEOUT_SECONDS=120
FFMPEG_BINARY=ffmpeg
FFPROBE_BINARY=ffprobe

# Backend audio preprocessing before sending audio to AI service
AUDIO_PREPROCESSING_ENABLED=true
AUDIO_PREPROCESSING_TIMEOUT_MS=900000
AUDIO_PREPROCESSING_FILTER=highpass=f=80,lowpass=f=8000,loudnorm=I=-16:TP=-1.5:LRA=11
AUDIO_PREPROCESSING_AUDIO_BITRATE=48k

# LLM
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4.1-mini
OPENAI_BASE_URL=https://api.openai.com/v1
LLM_TIMEOUT_SECONDS=60
LLM_MAX_RETRIES=5
LLM_TEMPERATURE=0.0
LLM_STRICT_JSON_SCHEMA=true
LLM_REFINE_MAX_OUTPUT_TOKENS=4096
LLM_SEGMENT_CHUNK_SECONDS=300
LLM_SEGMENT_MAX_OUTPUT_TOKENS=32768
LLM_MERGE_MAX_OUTPUT_TOKENS=8192
LLM_REASONING_MAX_OUTPUT_TOKENS=8192

# Frontend
VITE_BACKEND_API_URL=http://localhost:3000
